  "panels": [
    {
      "id": 1,
      "title": "AI 결정 (1h rate, 마켓별)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (market) (rate(openclaw_ai_decision_total[1h]))",
          "legendFormat": "AI {{market}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 2,
      "title": "RULE 결정 (1h rate, 마켓별)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (market) (rate(openclaw_rule_decision_total[1h]))",
          "legendFormat": "RULE {{market}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 3,
      "title": "AI vs RULE 비율 (24h)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "sum(increase(openclaw_ai_decision_total[24h])) / clamp_min(sum(increase(openclaw_ai_decision_total[24h])) + sum(increase(openclaw_rule_decision_total[24h])), 1)",
          "legendFormat": "AI 비율",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "auto"}
    },
    {
      "id": 4,
      "title": "매매 사이클 (5m rate, 마켓×결과)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 8, "y": 8, "w": 16, "h": 6},
      "targets": [
        {
          "expr": "rate(openclaw_agent_cycle_total[5m])",
          "legendFormat": "{{market}} / {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 5,
      "title": "거래 카운터 (1h 증가)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (side, market) (increase(openclaw_trade_total[1h]))",
          "legendFormat": "{{market}} {{side}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 6,
      "title": "누적 PnL (마켓별)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "openclaw_pnl_total",
          "legendFormat": "{{market}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
