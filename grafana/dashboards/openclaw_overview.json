    {
      "id": 7,
      "title": "신호 점수 (composite score)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "openclaw_signal_score",
          "legendFormat": "{{market}} / {{signal}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 100}, "overrides": []}
    },
    {
      "id": 8,
      "title": "API latency p95",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openclaw_api_latency_seconds_bucket[5m])) by (le, endpoint))",
